{
    "name": "psugh-website",
    "version": "3.0.0",
    "description": "Modern website for PowerShell Usergroup Hannover (PSUGH) - built with modern web technologies and deployed on GitHub Pages",
    "main": "index.html",
    "scripts": {
        "dev": "npx http-server -p 3000 -c-1",
        "build": "npm run lint-css && npm run minify-css",
        "minify-css": "cleancss -o css/styles.min.css css/styles.css",
        "lint-css": "stylelint css/*.css",
        "lint-html": "htmlhint *.html",
        "validate": "npm run lint-css && npm run lint-html && npm run validate-images",
        "validate-images": "node scripts/validate-images.js",
        "validate-seo": "node scripts/validate-seo.js",
        "serve": "npx http-server -p 3000 -c-1",
        "preview": "npm run build && npm run serve"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/PSUGH/PSUGH.github.io.git"
    },
    "keywords": [
        "powershell",
        "usergroup",
        "hannover",
        "community",
        "azure",
        "github-pages",
        "static-site"
    ],
    "author": "PowerShell Usergroup Hannover",
    "license": "CC-BY-3.0",
    "bugs": {
        "url": "https://github.com/PSUGH/PSUGH.github.io/issues"
    },
    "homepage": "https://www.psugh.org",
    "devDependencies": {
        "clean-css-cli": "^5.6.2",
        "htmlhint": "1.1.4",
        "stylelint": "^15.11.0",
        "stylelint-config-standard": "^34.0.0"
    },
    "browserslist": [
        "> 1%",
        "last 2 versions",
        "not dead"
    ]
}
