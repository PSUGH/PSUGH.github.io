# --- Dependency Management ---
# Automatically save the exact version in package.json (removes ^ or ~)
save-exact=true

# --- Security & Stability ---
# Minimum age of a release in milliseconds (7 days = 604800000)
min-release-age=604800000

# Level of security audit to fail the build (low, moderate, high, or critical)
audit-level=high

# Suppress the "Update npm" message
update-notifier=false

# Progress bar can slow down CI environments; set to false for speed
progress=false

# --- Performance ---
# Number of simultaneous requests to the registry
maxsockets=50